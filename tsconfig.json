{
  "compilerOptions": {
    /* Language & runtime */
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "node",

    /* Project structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Quality of life */
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Source maps */
    "sourceMap": true,

    /* Types */
    "types": ["node"]
  },
  "include": [
    "src",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}